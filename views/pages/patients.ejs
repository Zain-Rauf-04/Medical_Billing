<div class="patients-page">
  <div class="page-header">
    <div class="header-content">
      <h1>Patients Registry</h1>
      <p>
        Manage patient records, insurance details, and outstanding balances.
      </p>
    </div>
    <button class="add-btn">
      <img src="/icons/Add Patient.svg" alt="Add Patient Icon" />
      Add New Patient
    </button>
  </div>
  <div class="priority-wrapper">
    <div class="priority-heading">
      <img src="/icons/Pin-green Icon.svg" alt="Pin Green Icon" />
      <span>Priority Accounts</span>
    </div>
    <div class="priority-cards">
      <div class="priority-card">
        <div class="card-top">
          <img src="/images/Priority 1.jpg" alt="Priority 1" />
          <span class="badge urgent">URGENT</span>
        </div>
        <h3>Sarah Jenkins</h3>
        <p>ID: #PX-9921</p>
        <div class="divider"></div>
        <div class="card-footer">
          <span>Balance Due</span>
          <strong style="color: #ba1a1a">$1,240.00</strong>
        </div>
      </div>
      <div class="priority-card">
        <div class="card-top">
          <img src="/images/Priority 2.jpg" alt="Priority 2" />
          <span class="badge review">REVIEW</span>
        </div>
        <h3>Robert Miller</h3>
        <p>ID: #PX-8842</p>
        <div class="divider"></div>
        <div class="card-footer">
          <span>Last Visit</span>
          <strong>Oct 12, 2023</strong>
        </div>
      </div>
      <div class="priority-card">
        <div class="card-top">
          <img src="/images/Priority 3.jpg" alt="Priority 3" />
          <span class="badge stable">STABLE</span>
        </div>
        <h3>Elena Rodriguez</h3>
        <p>ID: #PX-7115</p>
        <div class="divider"></div>
        <div class="card-footer">
          <span>Next Appt.</span>
          <strong>Tomorrow</strong>
        </div>
      </div>
      <div class="pin-card">
        <div class="pin-icon">
          <img src="/icons/Star-blue Icon.svg" alt="Star Icon" />
        </div>
        <h4>Pin a Patient</h4>
        <p>Keep frequent accounts here</p>
      </div>
    </div>
  </div>
  <div class="registry-box">
    <div class="filters">
      <div class="filter-group">
        <div class="field">
          <label>Insurance Type</label>
          <select>
            <option>All Providers</option>
          </select>
        </div>
        <div class="field">
          <label>Status</label>
          <select>
            <option>All Statuses</option>
          </select>
        </div>
        <div class="field">
          <label>Balance Range</label>
          <select>
            <option>Any Balance</option>
          </select>
        </div>
      </div>
      <div class="filter-actions">
        <button class="outline-btn">
          <img src="/icons/Down Head Icon.svg" alt="Down Head Icon" />More
          Filters
        </button>
        <button class="outline-btn">
          <img src="/icons/Download 2 Icon.svg" alt="Download Icon" />Export CSV
        </button>
      </div>
    </div>
    <table>
      <thead>
        <tr>
          <th>Patient Name</th>
          <th>Date of Birth</th>
          <th>Gender</th>
          <th>Insurance Provider</th>
          <th>Balance Due</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>
            <div class="patient-cell">
              <img src="/images/Patient 1.jpg" alt="Patient 1" />
              <div>
                <h5>James Wilson</h5>
                <span>ID: 104-552</span>
              </div>
            </div>
          </td>
          <td>May 14, 1982</td>
          <td>Male</td>
          <td>Aetna Health</td>
          <td class="balance">$450.00</td>
          <td>
            <span class="status active"> Active </span>
          </td>
          <td>
            <button class="action-btn">
              <img src="/icons/3dots.svg" alt="3 Dots Icon" />
            </button>
          </td>
        </tr>
        <tr>
          <td>
            <div class="patient-cell">
              <img src="/images/Patient 3.jpg" alt="Patient 2" />
              <div>
                <h5>Linda Zhang</h5>
                <span>ID: 202-311</span>
              </div>
            </div>
          </td>
          <td>Oct 28, 1995/td></td>
          <td>Female</td>
          <td>Blue Shield</td>
          <td class="balance" style="color: #ba1a1a">$1,825.40</td>
          <td>
            <span class="status pending"> On Hold </span>
          </td>
          <td>
            <button class="action-btn">
              <img src="/icons/3dots.svg" alt="3 Dots Icon" />
            </button>
          </td>
        </tr>
        <tr>
          <td>
            <div class="patient-cell">
              <img src="/icons/Profile.svg" alt="Profile Icon" />
              <div>
                <h5>Marcus Thorne</h5>
                <span>ID: 405-998</span>
              </div>
            </div>
          </td>
          <td>Jan 03, 1968</td>
          <td>Male</td>
          <td>UnitedHealth</td>
          <td class="balance">$0.00</td>
          <td>
            <span class="status cleared"> Inactive </span>
          </td>
          <td>
            <button class="action-btn">
              <img src="/icons/3dots.svg" alt="3 Dots Icon" />
            </button>
          </td>
        </tr>
        <tr>
          <td>
            <div class="patient-cell">
              <img src="/images/Patient 3.jpg" alt="Profile 3" />
              <div>
                <h5>Alicia keys</h5>
                <span>ID: 112-443</span>
              </div>
            </div>
          </td>
          <td>Dec 12, 1990</td>
          <td>Female</td>
          <td>Medicare</td>
          <td class="balance">$210.50</td>
          <td>
            <span class="status active"> Cleared </span>
          </td>
          <td>
            <button class="action-btn">
              <img src="/icons/3dots.svg" alt="3 Dots Icon" />
            </button>
          </td>
        </tr>
      </tbody>
    </table>
    <div class="table-footer">
      <span> Showing 1-10 of 2,482 patients </span>
      <div class="pagination">
        <button>&lt;</button>
        <button class="active-page">1</button>
        <button>2</button>
        <button>3</button>
        <button>&gt;</button>
      </div>
    </div>
  </div>
</div>
