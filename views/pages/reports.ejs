<div class="page">
  <div class="reports-container">
    <div class="header">
      <div>
        <h1>Financial Insights</h1>
        <p>Performance overview for the current fiscal quarter.</p>
      </div>
      <div class="actions">
        <button class="btns btn">
          <img src="/icons/Appointment.svg" alt="Appointment Icon" />Last 90
          Days
        </button>
        <button class="btns btn-primary">
          <img src="/icons/Plus-white.svg" alt="Plus Icon" /> New Invoice
        </button>
      </div>
    </div>
    <div class="top">
      <div class="card">
        <div class="row">
          <span class="icon icon-green"
            ><img src="/icons/Wallet-green.svg" alt="Wallet Icon"
          /></span>
          <span class="card-green">+2.4%</span>
        </div>
        <p>Net Collection Rate</p>
        <h2 class="percentage">96.8%</h2>
        <div class="green-line"></div>
      </div>
      <div class="card">
        <div class="row">
          <span class="icon icon-brown"
            ><img src="/icons/Clock-brown.svg" alt="Clock Icon"
          /></span>
          <span class="card-red">-3 days</span>
        </div>
        <p>Days in AR</p>
        <h2 class="percentage">32.4</h2>
        <div class="mini">
          <div style="height: 20px"></div>
          <div style="height: 28px"></div>
          <div style="height: 23px"></div>
          <div style="height: 15px; background-color: #943700"></div>
        </div>
      </div>
      <div class="card">
        <div class="row">
          <span class="icon icon-blue"
            ><img src="/icons/Blue-tick.svg" alt="Blue Tick Icon"
          /></span>
          <span class="card-blue">Target: 98%</span>
        </div>
        <p>First Pass Clean Claim Rate</p>
        <h2 class="percentage">94.2%</h2>
        <p class="muted">SM • Improving trend</p>
      </div>
    </div>
    <div class="dashboard">
      <div class="middle-card revenue-card">
        <div class="card-header">
          <h2>Revenue vs. Collections</h2>
          <div class="legend">
            <div class="legend-item">
              <span class="legend-dot blue"></span>
              <p>Revenue</p>
            </div>
            <div class="legend-item">
              <span class="legend-dot green"></span>
              <p>Collections</p>
            </div>
          </div>
        </div>
        <div class="chart">
          <div class="line line1"></div>
          <div class="line line2"></div>
          <div class="line line3"></div>
          <div class="line line4"></div>
          <div class="bars">
            <div class="month">
              <div class="bar-group">
                <div class="bar revenue jan"></div>
                <div class="bar collection jan"></div>
              </div>
              <span>JAN</span>
            </div>
            <div class="month">
              <div class="bar-group">
                <div class="bar revenue feb"></div>
                <div class="bar collection feb"></div>
              </div>
              <span>FEB</span>
            </div>
            <div class="month">
              <div class="bar-group">
                <div class="bar revenue mar"></div>
                <div class="bar collection mar"></div>
              </div>
              <span>MAR</span>
            </div>
            <div class="month">
              <div class="bar-group">
                <div class="bar revenue apr"></div>
                <div class="bar collection apr"></div>
              </div>
              <span>APR</span>
            </div>
            <div class="month">
              <div class="bar-group">
                <div class="bar revenue may"></div>
                <div class="bar collection may"></div>
              </div>
              <span>MAY</span>
            </div>
            <div class="month">
              <div class="bar-group">
                <div class="bar revenue jun"></div>
                <div class="bar collection jun"></div>
              </div>
              <span>JUN</span>
            </div>
          </div>
        </div>
      </div>
      <div class="card payer-card">
        <h2>Payer Mix</h2>
        <div class="donut-wrapper">
          <div class="donut">
            <div class="donut-center">
              <span class="small-text">TOTAL</span>
              <h3>$1.2M</h3>
            </div>
          </div>
        </div>
        <div class="payer-list">
          <div class="payer-item">
            <div class="payer-left">
              <span class="square medicare"></span>
              <p>Medicare</p>
            </div>
            <strong>45%</strong>
          </div>
          <div class="payer-item">
            <div class="payer-left">
              <span class="square blue-shield"></span>
              <p>Blue Shield</p>
            </div>
            <strong>30%</strong>
          </div>
          <div class="payer-item">
            <div class="payer-left">
              <span class="square aetna"></span>
              <p>Aetna</p>
            </div>
            <strong>15%</strong>
          </div>
          <div class="payer-item">
            <div class="payer-left">
              <span class="square other"></span>
              <p>Other</p>
            </div>
            <strong>10%</strong>
          </div>
        </div>
      </div>
