            </div>
          </div>
          <div class="col frequency-col">Bi-Weekly</div>
          <div class="col recipient-col">cfo@health.org</div>
          <div class="col status-col">
            <span class="badge paused"> Paused </span>
          </div>
          <div class="col run-col">
