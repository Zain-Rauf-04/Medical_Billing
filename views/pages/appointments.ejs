<div class="page">
  <div class="card">
    <div class="progress">
      <div class="step completed">
        <div class="circle">✓</div>
        <span>Patient</span>
      </div>
      <div class="line"></div>
      <div class="step active">
        <div class="circle">2</div>
        <span>Services</span>
      </div>
      <div class="line"></div>
      <div class="step">
        <div class="circle">3</div>
        <span>Insurance</span>
      </div>
      <div class="line"></div>
      <div class="step">
        <div class="circle">4</div>
        <span>Review</span>
      </div>
    </div>
    <div class="content">
      <h2>Service Details</h2>
      <p class="subtitle">
        Enter the specific medical services and codes for this visit.
      </p>
      <div class="form-row">
        <div class="field">
          <label>DATE OF SERVICE</label>
          <input type="text" value="11/24/2023" />
        </div>
        <div class="field">
          <label>PROVIDER</label>
          <div class="select-box">
            <span>Dr. Sarah Chen, MD</span>
            <svg width="14" height="14" viewBox="0 0 20 20">
              <path
                d="M5 7L10 12L15 7"
                stroke="#6b7280"
                stroke-width="2"
                fill="none"
                stroke-linecap="round"
              />
            </svg>
          </div>
        </div>
        <div class="field">
          <label>FACILITY</label>
          <div class="select-box">
            <span>Northside General Hospital</span>
            <svg width="14" height="14" viewBox="0 0 20 20">
              <path
                d="M5 7L10 12L15 7"
                stroke="#6b7280"
                stroke-width="2"
                fill="none"
                stroke-linecap="round"
              />
            </svg>
          </div>
        </div>
      </div>
      <div class="table-card">
        <div class="table-header">
          <h3>Diagnosis &amp; Procedures</h3>
          <button class="add-btn">+ Add Row</button>
        </div>
        <table>
          <thead>
            <tr>
              <th>ICD-10 Code</th>
              <th>CPT Code</th>
              <th>Description</th>
              <th>Units</th>
              <th>Charge</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="blue">J01.90</td>
              <td class="blue">99213</td>
              <td class="table-desc">
                Office visit, established patient; mid-level severity
              </td>
              <td>1</td>
              <td class="price">$145.00</td>
              <td class="delete">
                <img src="/icons/Recyclebin-red.svg" alt="Recycle Bin" />
              </td>
            </tr>
            <tr class="empty">
              <td>
                <input type="text" placeholder="Search..." />
              </td>
              <td>
                <input type="text" placeholder="Search..." />
              </td>
              <td>
                <input
                  type="text"
                  placeholder="Start typing to find codes..."
                />
              </td>
              <td>0</td>
              <td>$0.00</td>
              <td>
                <svg width="18" height="18" viewBox="0 0 24 24">
                  <circle cx="12" cy="5" r="1.7" />
                  <circle cx="12" cy="12" r="1.7" />
                  <circle cx="12" cy="19" r="1.7" />
                </svg>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="summary-wrap">
        <div class="summary-card">
          <div class="summary-row">
            <span>Subtotal Charges</span>
            <span>$145.00</span>
          </div>
          <div class="summary-row">
            <span>Adjustments</span>
            <span>$0.00</span>
          </div>
          <div class="summary-divider"></div>
          <div class="summary-row total">
            <span>Total Claim</span>
            <span>$145.00</span>
          </div>
        </div>
      </div>
      <div class="footer">
        <button class="back-btn">
          <svg width="18" height="18" viewBox="0 0 24 24">
            <path
              d="M15 6L9 12L15 18"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          <span>Back</span>
        </button>
        <div class="footer-right">
          <button class="draft-btn">Save as Draft</button>
          <button class="continue-btn">Continue to Insurance</button>
        </div>
      </div>
    </div>
  </div>
</div>
