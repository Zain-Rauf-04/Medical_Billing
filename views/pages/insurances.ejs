<div class="claims-page">
  <div class="topbar">
    <div class="title-block">
      <p>Claims Management &gt;<span> Active Tracking</span></p>
      <h1>Insurance Claim Tracking</h1>
    </div>
    <div class="top-actions">
      <button class="btn ghost">
        <img src="/icons/Down Head Icon.svg" alt="Down Head Icon" />
        Filter
      </button>
      <button class="btn primary">
        <img src="/icons/Verified-white Icon.svg" alt="Verified Icon" />
        Verify Insurance
      </button>
    </div>
  </div>
  <div class="layout">
    <div class="left">
      <div class="card">
        <div class="card-head">
          <h3>Active Claims</h3>
          <span class="card-head-pill">24 Processing</span>
        </div>
        <div class="claim-item">
          <div class="claim-icon claim-icon-green">
            <img src="/icons/Game-green Icon.svg" alt="Game Icon" />
          </div>
          <div class="meta">
            <h4>CLM-92831 - Thompson, James</h4>
            <p>
              <span
                ><img src="/icons/Building Icon.svg" alt="Building Icon" />Blue
                Cross Shield</span
              >
              <span
                ><img src="/icons/Clock Icon.svg" alt="Clock Icon" /> Submitted
                2d ago</span
              >
            </p>
          </div>
          <div class="amount">$2,450.00</div>
          <span class="tag success"
            ><span class="tag-dot success-dot"></span>In Review</span
          >
        </div>
        <div class="claim-item">
          <div class="claim-icon claim-icon-red">
            <img src="/icons/Warning-red Icon.svg" alt="Warning Icon" />
          </div>
          <div class="meta">
            <h4>CLM-92750 - Rodriguez, Elena</h4>
            <p>
              <span
                ><img src="/icons/Building Icon.svg" alt="Building Icon" />Aetna
                PPO</span
              >
              <span
                ><img src="/icons/Clock Icon.svg" alt="Clock Icon" /> Submitted
                5d ago</span
              >
            </p>
          </div>
          <div class="amount">$1,120.00</div>
          <span class="tag danger"
            ><span class="tag-dot danger-dot"></span>Denied</span
          >
        </div>
        <div class="claim-item">
          <div class="claim-icon claim-icon-blue">
            <img src="/icons/Arrow Head Right Icon.svg" alt="Arrow Head Icon" />
          </div>
          <div class="meta">
            <h4>CLM-92902 - Smith, Robert</h4>
            <p>
              <span
                ><img
                  src="/icons/Building Icon.svg"
                  alt="Building Icon"
                />United Healthcare</span
              >
              <span
                ><img src="/icons/Clock Icon.svg" alt="Clock Icon" /> Sent
                Today</span
              >
            </p>
          </div>
          <div class="amount">$840.00</div>
          <span class="tag pending"
            ><span class="tag-dot pending-dot"></span>Clearinghouse</span
          >
        </div>
        <div class="view-all">View All Active Claims (24)</div>
      </div>
      <div class="card details">
        <div class="details-top">
          <div class="details-title">
            <div class="details-head">
              <h3>Claim Details: CLM-92750</h3>
              <span class="danger-badge">Critical Action</span>
            </div>
            <div class="details-description">
              <p class="sub">Patient: Elena Rodriguez | DOB: 10/12/2023</p>
            </div>
          </div>
          <div class="amount-box">
            <span>Claim Total</span>
            <h2>$1,120.00</h2>
          </div>
        </div>
        <div class="timeline">
          <div class="step">
            <div class="circle done">
              <img src="/icons/Circle Tick-white.svg" alt="Circle Tick" />
            </div>
            <div class="title">Submitted</div>
            <div class="time">Oct 14, 09:30 AM</div>
          </div>
          <div class="step">
            <div class="circle done">
              <img src="/icons/Circle Tick-white.svg" alt="Circle Tick" />
            </div>
            <div class="title">Clearinghouse</div>
            <div class="time">Oct 14, 02:45 PM</div>
          </div>
          <div class="step">
            <div class="circle done">
              <img src="/icons/Circle Tick-white.svg" alt="Circle Tick" />
            </div>
            <div class="title">Payer Received</div>
            <div class="time">Oct 15, 11:20 AM</div>
          </div>
          <div class="step">
            <div class="circle failed">
              <img src="/icons/Circle Cross-white.svg" alt="Circle Cross" />
            </div>
            <div class="title">Denied</div>
            <div class="time">Oct 19, 04:15 PM</div>
          </div>
        </div>
        <div class="detail-grid">
          <div class="box box-left">
            <h4>Submitter Information</h4>
            <div class="row">
              <span>Provider</span>
              <b>Dr. Alan Grant</b>
            </div>
            <div class="row">
              <span>Clinic</span>
              <b>Main Street Clinic</b>
            </div>
            <div class="row">
              <span>NPI</span>
              <b>1928374650</b>
            </div>
            <div class="row">
              <span>Code</span>
              <b>99213 - Level 3 Visit</b>
            </div>
          </div>
          <div class="box box-danger">
            <h4>Payer Response (Denial)</h4>
            <div class="header">
              <div class="code">REASON CODE: CO-16</div>
              <div class="message">
                Claim lacks information or has a submission error that is needed
                for adjudication.
              </div>
            </div>
            <div class="divider"></div>
            <div class="recommendation">
              <div class="title">RECOMMENDED ACTION:</div>
              <div class="text">
                "Verify patient secondary insurance details. Possible COB
                (Coordination of Benefits) conflict."
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="right">
      <section class="verification-card">
        <h2>Insurance Verification</h2>
        <p class="description">
          Real-time eligibility check for new patients or coverage updates.
        </p>
        <div class="field">
          <label>Subscriber ID</label>
          <input type="text" placeholder="ABC123456789" />
        </div>
        <div class="input-row">
          <div class="field">
            <label>Payer</label>
            <div class="select-box">
              <select>
                <option>BlueCross</option>
              </select>
              <img src="/icons/Down Angle.svg" alt="Down Angle" />
            </div>
          </div>
          <div class="field">
            <label>Service Type</label>
            <div class="select-box">
              <select>
                <option>Diagnostic</option>
              </select>
              <img src="/icons/Down Angle.svg" alt="Down Angle" />
            </div>
          </div>
        </div>
        <button class="verify-btn">Check Eligibility</button>
      </section>
      <div class="card followup">
        <section class="followup-card">
          <div class="followup-header">
            <h2>AR Follow-ups</h2>
            <img src="/icons/3dots-blue.svg" alt="3 Dots" />
          </div>
          <div class="task">
            <div class="check">
              <input type="checkbox" />
            </div>
            <div class="task-info">
              <h3>Call BCBS for CLM-92750</h3>
              <p>Check COB status with payer agent.</p>
              <div class="bottom">
                <span class="badge high"> HIGH PRIO </span>
                <span class="time"> Due: 2:00 PM </span>
              </div>
            </div>
          </div>
          <div class="task">
            <div class="check">
              <input type="checkbox" />
            </div>
            <div class="task-info">
              <h3>Fax Medical Records - CLM-8821</h3>
              <p>Support for Level 4 visit upgrade.</p>
              <div class="bottom">
                <span class="badge routine"> ROUTINE </span>
                <span class="time"> Due: EOD </span>
              </div>
            </div>
          </div>
          <div class="task completed">
            <div class="check">
              <input checked type="checkbox" />
            </div>
            <div class="task-info">
              <h3>Update Patient ID - Elena R.</h3>
              <p>Completed by Dr. Chen</p>
            </div>
          </div>
          <button class="add-btn">Add New Task</button>
        </section>
        <div class="card insight-card">
          <div class="card-header">
            <div class="insight-title">
              <img src="/icons/Magic-blue.svg" alt="Magic Icon" />
              <h2>Quick Insights</h2>
            </div>
          </div>
          <div class="progress-section">
            <div class="progress-top">
              <span>Clean Claim Rate</span>
              <strong>92%</strong>
            </div>
            <div class="progress-bar">
              <div class="progress-fill"></div>
            </div>
          </div>
          <p class="insight-description">
            Average turnaround:
            <strong>14.2 days</strong>
            <span>(↑ 1.2 from last month)</span>
          </p>
          <button class="insight-add-btn">
            <img src="/icons/Plus-white.svg" alt="Plus Icon" />
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
